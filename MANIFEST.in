# MANIFEST.in - Controls which files go into sdist (source distribution)

# Core files
include LICENSE
include README.md
include .env.example
include requirements.txt
include requirements-dev.txt
include pytest.ini

# The critical prompt file (and any other package data)
include pocarchitect/POC_Architect_Prompt.md

# Recursively include any Markdown or data files inside the package
recursive-include pocarchitect *.md
recursive-include pocarchitect *.txt

# Exclude tests, docs, and examples from the distribution
prune tests
prune docs
prune example_usage
prune .github
prune .pytest_cache
prune .ruff_cache
prune .mypy_cache
