# POCArchitect AI Agent - Environment Variables
# Copy this file to .env and fill in your keys

# xAI / Grok (recommended)
XAI_API_KEY=xai-your_key_here

# OpenAI
OPENAI_API_KEY=sk-your_openai_key_here

# Groq (fast & cheap)
GROQ_API_KEY=gsk-your_groq_key_here

# Optional advanced settings (used by CLI flags)
# TEMPERATURE=0.2
# MAX_TOKENS=16000