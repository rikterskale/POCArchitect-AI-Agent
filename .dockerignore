# ──────────────────────────────────────────────────────────────
# .dockerignore - Optimized for POCArchitect (prompt now included)
# ──────────────────────────────────────────────────────────────

# Version control
.git
.gitignore
.gitattributes

# Python bytecode / caches
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
env.bak/
venv.bak/

# Local development
.env
.env.example
.dockerignore
.docker/
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Documentation and examples (only root-level; prompt inside package is kept)
docs/
example_usage/
tests/
README.md
CHANGELOG.md
POCArchitect_Example_Report.md

# Build artifacts
dist/
build/
*.egg-info/
htmlcov/
.coverage
coverage.xml
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Temporary / logs / reports
*.log
tmp/
temp/
reports/
*.tmp

# Docker specific
Dockerfile*
.dockerfile*

# Credentials
**/*.key
**/*.pem
**/*.crt
